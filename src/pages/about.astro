---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About">
  <!--div class="flex flex-col items-center justify-center h-full"-->
  <div class="flex flex-col items-center">
    <h1 class="text-4xl font-bold mb-8 text-nvim-blue">About Me</h1>
    <div class="text-center">
      <p class="mb-4">version 0.0.1</p>
    </div>
  </div>

  <div class="flex flex-col text-left justify-left p-10">

    <h1 class="text-2xl font-bold mb-4 text-nvim-blue">學歷</h1>
    <ul class="mb-8">
      <li><a href="https://www.csie.ntnu.edu.tw/" class="text-nvim-green">國立臺灣師範大學 資訊工程學系</a><br/>
          | 2021-09 - 2025-06</li>
      <li><a href="https://www.clhs.tyc.edu.tw/home" class="text-nvim-green">國立中央大學附屬中壢高級中學</a><br/>
          | 2018-09 - 2021-06</li>
    </ul>

    <h1 class="text-2xl font-bold mb-4 text-nvim-blue">工作經歷</h1>
    <ul class="mb-8">
      <li><a href="https://www.gss.com.tw/" class="text-nvim-green">叡揚資訊</a> 實習生 @ 資安直屬事業處<br/>
          | 2024-07 - 2024-12</li>
    </ul>

    <h1 class="text-2xl font-bold mb-4 text-nvim-blue">教育經歷</h1>
    <ul class="mb-8">
      <li>113-2 資安攻防演練 助教<br/>
          | 2025-03 - 2025-06</li>
      <li>113-2 程式設計（二） 助教<br/>
          | 2025-03 - 2025-06</li>
      <li>遠距實習教師：花蓮縣立富里國中 [英文]<br/>
          | 2024-02 - 2025-05</li>
      <li>遠距實習教師：花蓮縣立萬榮國中 [數學]<br/>
          | 2024-09 - 2024-12</li>
      <li>暑期實習教師：花蓮縣立東里國中 [閱讀、數學]<br/>
          | 2023-07</li>
      <li>高中數學家教<br/>
          | 2023-03 - NOW</li>
      <li>數位學伴：臺中市東汴國小 [數學]<br/>
          | 2023-03 - 2023-06<br/>
          | 獲優良大學伴</li>
    </ul>

    <h1 class="text-2xl font-bold mb-4 text-nvim-blue">證照</h1>
    <ul class="mb-8">
      <li>IPAS 初級資安工程師<br/>
          | 2025-01</li>
    </ul>

  </div>
</Layout>
